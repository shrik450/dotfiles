# --- General ---
set -g default-terminal "tmux-256color"
{{ if eq .chezmoi.os "darwin" -}}
set -ag terminal-overrides ",xterm-ghostty:RGB"
set -as terminal-features ',xterm-ghostty:extkeys'
{{ else -}}
set -ag terminal-overrides ",xterm-256color:RGB"
set -as terminal-features ',xterm-256color:extkeys:clipboard'
set -g set-clipboard on
{{ end -}}
set -g mouse on
set -g history-limit 50000
set -g escape-time 0
set -g focus-events on
set -g extended-keys on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on

# --- Prefix: Ctrl+Space ---
unbind C-b
set -g prefix C-Space
bind C-Space send-prefix

# --- Tab (Window) Management ---
bind c new-window -c "#{pane_current_path}"
bind , command-prompt -I "#W" "rename-window '%%'"
bind x confirm-before -p "Kill window '#W'? (y/n)" kill-window

# --- Tab Navigation: Alt+H / Alt+L ---
bind -n M-h previous-window
bind -n M-l next-window

# --- Copy Mode (vi-style) ---
setw -g mode-keys vi
bind [ copy-mode
bind / copy-mode \; send-keys ?
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi V send -X select-line
{{ if eq .chezmoi.os "darwin" -}}
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi Enter send -X copy-pipe-and-cancel "pbcopy"
{{ else -}}
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "~/.local/bin/osc52-copy"
bind -T copy-mode-vi Enter send -X copy-pipe-and-cancel "~/.local/bin/osc52-copy"
{{ end -}}
bind -T copy-mode-vi Escape send -X cancel

# --- fzf Window Switcher: prefix+f ---
bind f display-popup -E \
  "tmux list-windows -F '#{window_index}: #{window_name}#{?window_active, (active),}' \
  | fzf --reverse --header='Switch to window' \
  | cut -d: -f1 \
  | xargs -I{} tmux select-window -t :{}"

# --- fzf Scrollback Search: prefix+F ---
bind F display-popup -E -w 80% -h 80% \
  "tmux capture-pane -pS -50000 \
  | fzf --tac --no-sort --header='Search scrollback (result copied to clipboard)' \
{{- if eq .chezmoi.os "darwin" }}
  | pbcopy"
{{- else }}
  | xclip -selection clipboard"
{{- end }}

# --- Open URLs / File Paths: prefix+o ---
bind o display-popup -E -w 80% -h 60% "$HOME/.local/bin/tmux-open-picker"

# --- Reload Config ---
bind r source-file ~/.config/tmux/tmux.conf \; display "Config reloaded"

# --- Status Bar: GitHub Dark + Powerline ---
set -g status-position bottom
set -g status-style "bg=#161b22,fg=#c9d1d9"
set -g status-left-length 30
set -g status-right-length 30
set -g status-left "#[fg=#0d1117,bg=#58a6ff,bold] #S #[fg=#58a6ff,bg=#161b22,nobold]"
set -g status-right "#[fg=#30363d,bg=#161b22]#[fg=#8b949e,bg=#30363d] %H:%M "

set -g window-status-format "#[fg=#161b22,bg=#0d1117]#[fg=#8b949e,bg=#0d1117] #I #W #[fg=#0d1117,bg=#161b22]"
set -g window-status-current-format "#[fg=#161b22,bg=#58a6ff]#[fg=#0d1117,bg=#58a6ff,bold] #I #W #[fg=#58a6ff,bg=#161b22]"
set -g window-status-separator ""

set -g message-style "bg=#58a6ff,fg=#0d1117"
set -g mode-style "bg=#264f78,fg=#c9d1d9"
